  "keyFeatures": [
    "Live draughts games with real-time WebSocket play",
    "Multiple draughts variants: Standard (10x10), Frisian, Antidraughts, Frysk!, Breakthrough, Russian, Brazilian",
    "Arenas and Swiss tournaments",
    "Tactics puzzles with spaced repetition training",
    "Game analysis with Scan 3.1 engine integration",
    "Collaborative studies and shared analysis",
    "Simultaneous exhibitions (simuls)",
    "Computer AI opponents via Draughtsnet",
    "OAuth2 API for third-party integrations and bots",
    "27-language i18n support via Crowdin",
    "TV channels for featured live games",
    "Teams, forums, and community features"
  ],
  "publicApiSurface": [
    "GET /api/user/:name — Get public user data",
    "GET /api/user/:name/activity — User activity feed",
    "GET /api/game/:id — Export a single game",
    "GET /api/games/user/:username — Export games by user",
    "POST /api/users — Get multiple users by IDs",
    "GET /api/tournament — List current tournaments",
    "GET /api/tournament/:id — Get tournament details",
    "GET /api/tournament/:id/results — Tournament results",
    "POST /api/tournament — Create a tournament",
    "POST /api/challenge/:user — Create a challenge",
    "GET /api/account — Get authenticated user account",
    "GET /api/account/playing — Current games of authenticated user",
    "GET /api/bot/game/stream/:id — Stream a bot game",
    "POST /api/bot/game/:id/move/:uci — Make a bot move",
    "GET /api/stream/event — Stream incoming events",
    "POST /api/stream/games-by-users — Stream games by user list",
    "GET /api/simul — List active simuls",
    "POST /api/swiss/new/:teamId — Create a Swiss tournament",
    "GET /api/status — Server status"
  ]
}
